# LLM + generation
HF_TOKEN=                      # HuggingFace, for model + dataset access
OPENAI_API_KEY=                # teacher model for synthetic data + LLM judge

# Observability
LANGCHAIN_API_KEY=             # LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=medscriptai

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Data stores
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://medscript:medscript@localhost:5432/medscript

# Model artifacts
BASE_MODEL=meta-llama/Llama-3.1-8B-Instruct
ADAPTER_REPO=your-hf-username/medscriptai-adapter
